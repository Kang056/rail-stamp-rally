# Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# TDX API credentials (for the data ingestion script)
TDX_CLIENT_ID=your-tdx-client-id
TDX_CLIENT_SECRET=your-tdx-client-secret
